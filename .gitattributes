# Enforce consistent line endings across all platforms
# LF for version control, CRLF on Windows checkout

* text=auto

# Python files - always LF
*.py text eol=lf
*.pyw text eol=lf
*.pyx text eol=lf
*.pxd text eol=lf

# Shell scripts - always LF
*.sh text eol=lf
*.bash text eol=lf

# Batch files - always CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Config files - always LF
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
.env* text eol=lf

# Markdown - always LF
*.md text eol=lf

# Documentation - always LF
*.txt text eol=lf
*.rst text eol=lf

# Binary files - no conversion
*.pkl binary
*.joblib binary
*.h5 binary
*.pth binary
*.so binary
*.db binary
*.sqlite binary

# Images - no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
